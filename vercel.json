{
  "buildCommand": "pip install --no-cache-dir -r requirements.txt",
  "builds": [
    {
      "src": "vss/api/index.py",
      "use": "@vercel/python@3.12",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12",
        "pythonVersion": "3.12"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PIP_NO_CACHE_DIR": "1"
  }
}